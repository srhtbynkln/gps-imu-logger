# Bu bir SABLON. Gercek surumu icin:
#   cp keystore.properties.example keystore.properties
# ve asagidaki degerleri kendi keystore'una gore doldur.
# keystore.properties ve *.jks GITIGNORE'ludur; repoya ASLA girmez.

# .jks dosyasinin yolu (kok dizine gore). Ornek: keystore'u repo kokune koyduysan:
storeFile=gps-imu-release.jks

# keytool ile belirledigin sifreler ve alias:
storePassword=BURAYA_KEYSTORE_SIFRESI
keyAlias=gpsimu
keyPassword=BURAYA_ANAHTAR_SIFRESI
